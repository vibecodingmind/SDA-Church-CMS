# Database - use Docker: postgresql://postgres:postgres@localhost:5432/church_cms
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/church_cms?schema=public"

# JWT - use a strong secret in production (min 32 chars)
JWT_SECRET="your-super-secret-key-min-32-chars"

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# CORS - add your frontend URL when deployed
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=10
LOGIN_LOCKOUT_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900
PORT=3000
NODE_ENV=development
